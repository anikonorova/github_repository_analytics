{
    "workbench.editorAssociations": {
        "*.parquet": "duckdb.dataFileViewer",
        "*.csv": "duckdb.dataFileViewer",
        "*.tsv": "duckdb.dataFileViewer"
    },
    "duckdb.databases": [
        {
            "alias": "analytics",
            "type": "file",
            "path": "${workspaceFolder}/database/analytics.db",
            "readOnly": true,
            "attached": false
        }
    ],
    "duckdb.defaultDatabase": "analytics"
}